{
  "name": "find-and-read",
  "description": "Find a symbol across the source tree and read the file containing it.",
  "steps": [
    {
      "name": "search-symbol",
      "tool": "Search",
      "args": { "symbol": "computeTotal", "contextLines": 2 }
    },
    {
      "name": "read-target",
      "tool": "Read",
      "args": { "path": "src/billing.ts", "mode": "signatures" }
    }
  ]
}
